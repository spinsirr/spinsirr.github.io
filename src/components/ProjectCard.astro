---
import type { Project } from '../consts';

interface Props {
	project: Project;
}
const { project } = Astro.props;
const { name, blurb, tags, href, repo, stars, badge } = project;
const showRepo = repo && repo !== href;
---

<article class="proj">
	{href ? <a class="overlay" href={href} target="_blank" rel="noopener" aria-label={name} /> : null}
	<header>
		<h3>{name}</h3>
		{badge ? <span class="badge">{badge}</span> : null}
	</header>

	<p>{blurb}</p>

	<ul class="tags">
		{tags.map((t) => <li>{t}</li>)}
	</ul>

	<footer>
		<span class="stars">{stars ? `★ ${stars}` : ''}</span>
		<span class="actions">
			{showRepo ? <a class="link" href={repo} target="_blank" rel="noopener">Source</a> : null}
			{href ? <a class="link" href={href} target="_blank" rel="noopener">{showRepo ? 'Visit' : 'GitHub'} ↗</a> : null}
		</span>
	</footer>
</article>

<style>
	.proj {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 0.9rem;
		padding: 1.8rem;
		min-height: 220px;
	}
	.overlay {
		position: absolute;
		inset: 0;
		z-index: 1;
	}
	.proj:hover {
		background: var(--bg-2);
	}
	header {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 0.6rem;
	}
	h3 {
		font-size: clamp(1.3rem, 2.4vw, 1.8rem);
	}
	p {
		margin: 0;
		flex: 1;
		font-size: 0.95rem;
		color: var(--fg-2);
		max-width: 42ch;
	}
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}
	.tags li {
		font-family: var(--font-mono);
		font-size: 0.7rem;
		color: var(--fg-3);
		border: 1px solid var(--line);
		padding: 0.16rem 0.45rem;
	}
	footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
		margin-top: 0.3rem;
		padding-top: 0.9rem;
		border-top: 1px solid var(--line);
	}
	.stars {
		font-family: var(--font-mono);
		font-size: 0.8rem;
		color: var(--accent);
	}
	.actions {
		position: relative;
		z-index: 2;
		display: inline-flex;
		gap: 0.9rem;
	}
	.link {
		font-family: var(--font-mono);
		font-size: 0.76rem;
		color: var(--fg-2);
	}
	.link:hover {
		color: var(--accent);
	}
</style>
