---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate } = Astro.props;

const postUrl = new URL(Astro.url.pathname, Astro.site).toString();
const blogLd = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: title,
	description,
	datePublished: pubDate.toISOString(),
	...(updatedDate ? { dateModified: updatedDate.toISOString() } : {}),
	author: { '@type': 'Person', name: 'Spencer Zhao', url: 'https://github.com/spinsirr' },
	url: postUrl,
	mainEntityOfPage: postUrl,
};
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<script type="application/ld+json" set:html={JSON.stringify(blogLd)} />
	</head>
	<body>
		<Header />
		<main class="section">
			<article class="wrap">
				<div class="toprow">
					<a class="back" href="/blog">← All posts</a>
					<button class="copy-md" type="button" data-copy-md aria-label="Copy this post as Markdown">
						<svg viewBox="0 0 16 16" aria-hidden="true"><path fill="currentColor" d="M4 1.5H3a2 2 0 0 0-2 2V14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V3.5a2 2 0 0 0-2-2h-1v1h1a1 1 0 0 1 1 1V14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3.5a1 1 0 0 1 1-1h1v-1Z"></path><path fill="currentColor" d="M9.5 1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-3a.5.5 0 0 1-.5-.5v-1a.5.5 0 0 1 .5-.5h3Zm-3-1A1.5 1.5 0 0 0 5 1.5v1A1.5 1.5 0 0 0 6.5 4h3A1.5 1.5 0 0 0 11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3Z"></path></svg>
						<span>Copy as Markdown</span>
					</button>
				</div>
				<header class="head">
					<div class="meta">
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<span class="updated">· updated <FormattedDate date={updatedDate} /></span>
							)
						}
					</div>
					<h1>{title}</h1>
					{description && <p class="desc">{description}</p>}
				</header>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />

		<style>
			article {
				max-width: 720px;
			}
			.toprow {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 1rem;
				margin-bottom: 2rem;
			}
			.back {
				font-family: var(--font-mono);
				font-size: 0.85rem;
				color: var(--fg-3);
			}
			.back:hover {
				color: var(--fg);
			}
			.copy-md {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				font-family: var(--font-mono);
				font-size: 0.74rem;
				color: var(--fg-2);
				background: transparent;
				border: 1px solid var(--line);
				border-radius: 0;
				padding: 0.35rem 0.6rem;
				cursor: pointer;
				white-space: nowrap;
				transition:
					color 0.16s ease,
					border-color 0.16s ease;
			}
			.copy-md:hover {
				color: var(--fg);
				border-color: var(--fg);
			}
			.copy-md svg {
				width: 14px;
				height: 14px;
			}
			.head {
				margin-bottom: 2.5rem;
				padding-bottom: 2rem;
				border-bottom: 1px solid var(--border);
			}
			.meta {
				font-family: var(--font-mono);
				font-size: 0.82rem;
				color: var(--text-mute);
				margin-bottom: 1rem;
			}
			.updated {
				font-style: italic;
			}
			.head h1 {
				margin: 0;
			}
			.desc {
				margin: 1rem 0 0;
				font-size: 1.15rem;
				color: var(--text-dim);
			}
			/* Markdown content lives in the slot, so reach it with :global. */
			.prose {
				font-size: 1.05rem;
			}
			.prose :global(h2) {
				margin-top: 2.5rem;
				font-size: 1.6rem;
			}
			.prose :global(h3) {
				margin-top: 2rem;
			}
			.prose :global(a) {
				color: var(--accent);
				text-decoration: underline;
				text-underline-offset: 3px;
			}
			.prose :global(a:hover) {
				color: #fff;
			}
			.prose :global(ul),
			.prose :global(ol) {
				padding-left: 1.3rem;
				color: var(--text-dim);
			}
			.prose :global(li) {
				margin-bottom: 0.5rem;
			}
			.prose :global(img) {
				border-radius: var(--radius-sm);
				border: 1px solid var(--border);
			}
		</style>
		<script>
			const btn = document.querySelector('[data-copy-md]');
			if (btn) {
				const label = btn.querySelector('span');
				const orig = label ? label.textContent : '';
				btn.addEventListener('click', async () => {
					const url = location.pathname.replace(/\/+$/, '') + '.md';
					try {
						const md = await fetch(url).then((r) => r.text());
						await navigator.clipboard.writeText(md);
						if (label) {
							label.textContent = 'Copied ✓';
							setTimeout(() => (label.textContent = orig), 1800);
						}
					} catch (e) {
						if (label) {
							label.textContent = 'Copy failed';
							setTimeout(() => (label.textContent = orig), 1800);
						}
					}
				});
			}
		</script>
	</body>
</html>
